# ============================================
# application.properties.example
# 复制此文件为 application.properties 并填入实际值
# 或设置对应的环境变量
# ============================================

# NapCat WebSocket 配置
NAPCT_WS_URL=ws://127.0.0.1:5701/?access_token=your_token
NAPCT_WS_BASE_URL=ws://127.0.0.1:5700
ONEBOT_HTTP_BASE_URL=http://127.0.0.1:5700
ONEBOT_ACCESS_TOKEN=your_access_token

# AI 服务配置 (OpenAI 兼容 API)
BAILIAN_API_KEY=sk-your-key
BAILIAN_BASE_URL=https://api.deepseek.com/v1/chat/completions
BAILIAN_CHAT_MODEL=deepseek-v4-pro
BAILIAN_TIMEOUT_MS=90000
BAILIAN_MAX_RETRIES=2

# Agent 服务配置
AGENT_API_KEY=sk-your-key
AGENT_BASE_URL=https://api.deepseek.com/v1/chat/completions
AGENT_MODEL=deepseek-v4-pro
AGENT_TIMEOUT_MS=90000
AGENT_MAX_RETRIES=2

# 兼容旧版
DASHSCOPE_API_KEY=sk-your-key

# 目标群号
TARGET_GROUP_ID=0

# 调试模式
DEBUG=false

# 私聊白名单
PRIVATE_WHITELIST_ENABLED=false

# 机器人 QQ 号
BOT_QQ=0

# 管理员 QQ 号
ADMIN_QQ=0

# 允许的群号（逗号分隔）
ALLOWED_GROUPS=

# 预加载的群号（逗号分隔）
PRELOAD_GROUPS=

# 允许私聊的用户（逗号分隔）
ALLOWED_PRIVATE_USERS=

# 数据库配置
DB_URL=jdbc:mysql://localhost:3306/candybear_db
DB_USER=candybear
DB_PASSWORD=your_password
DB_POOL_MAX_SIZE=10
DB_POOL_MIN_IDLE=2
